{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "init: flutter create platforms",
            "type": "shell",
            "command": "flutter",
            "args": [
                "create",
                "--platforms=windows,macos,linux",
                "--org=com.fish-ken",
                "."
            ],
            "problemMatcher": []
        },
        {
            "label": "init: flutter pub get",
            "type": "shell",
            "command": "flutter",
            "args": [
                "pub",
                "get"
            ],
            "problemMatcher": []
        },
        {
            "label": "init: full",
            "dependsOrder": "sequence",
            "dependsOn": [
                "init: flutter create platforms",
                "init: flutter pub get",
                "build_runner: build"
            ],
            "problemMatcher": []
        },
        {
            "label": "build_runner: build",
            "type": "shell",
            "command": "dart",
            "args": [
                "run",
                "build_runner",
                "build",
                "--delete-conflicting-outputs"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": false,
                "showReuseMessage": false
            }
        },
        {
            "label": "build_runner: watch",
            "type": "shell",
            "command": "dart",
            "args": [
                "run",
                "build_runner",
                "watch",
                "--delete-conflicting-outputs"
            ],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "build_runner: clean",
            "type": "shell",
            "command": "dart",
            "args": [
                "run",
                "build_runner",
                "clean"
            ],
            "problemMatcher": []
        }
    ]
}
